# 操作系统自动生成文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 编辑器/IDE 配置文件
.idea/
.vscode/
*.swp
*.swo
*~

# 依赖包目录（Node.js项目必备，Hexo/VitePress都用）
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# 博客生成的 静态文件目录（根据你的框架选，都加上最安全）
public/
dist/
build/
output/

# 日志、临时文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.temp/
.tmp/

# 自定义忽略（可选）
# 本地配置文件
_config.local.yml
# 域名文件（GitHub Pages会自动生成，不用提交）
CNAME